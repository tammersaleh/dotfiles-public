#!/usr/bin/env bash

set -Eeuo pipefail
shopt -s inherit_errexit
trap 'echo "$0 failed at line $LINENO: $BASH_COMMAND"' ERR
[[ -v DEBUG ]] && set -x

main() {
  [[ $# -eq 1 ]] || usage "Wrong number of arguments"
  v "$HOME/shit/$(date +%Y-%m-%d).$1"
}

usage() {
  [[ $# -gt 0 ]] && echo "  ERROR: $*"
  local me=$(basename "$0")
  cat <<-EOF

  USAGE: $me SUFFIX

  creates a quick scratch file of this type.

  Examples:

    $me md
    $me sh
	EOF
  exit 1
}

main "$@"
