# Find the subcommand position by scanning for the first non-flag argument after the command name.
# This handles cases where flags appear before the subcommand (e.g., alias claude='claude --flag').
local subcmd_pos=0
local subcmd=""
local -a known_commands=(agents attach auth auto-mode doctor install kill logs mcp plugin plugins project remote-control respawn rm setup-token stop ultrareview update upgrade)
local i
for (( i=2; i <= ${#words}; i++ )); do
  # Skip flags and their values
  [[ "$words[$i]" == -* ]] && continue
  # Check if this word is a known subcommand
  if (( ${known_commands[(Ie)$words[$i]]} )); then
    subcmd_pos=$i
    subcmd="$words[$i]"
    break
  fi
done

# If no subcommand found yet, fall through to main _arguments
if [[ -n "$subcmd" ]]; then
# Calculate positions relative to the subcommand
local sub1=$(( subcmd_pos + 1 ))

case $subcmd in
  agents)
    _arguments -s \
      '*--add-dir[Additional directory to allow tool access to in dispatched sessions (repeatable)]:directory:_files -/' \
      '--allow-dangerously-skip-permissions[Make bypass-permissions mode available to dispatched sessions without defaulting to it]' \
      '--cwd[Show only background sessions started under path]:path:_files -/' \
      '--dangerously-skip-permissions[Alias for --permission-mode bypassPermissions]' \
      '--effort[Default effort level for sessions dispatched from agent view]:level:(low medium high xhigh max)' \
      '(-h --help)'{-h,--help}'[Display help for command]' \
      '*--mcp-config[MCP server configuration to apply to dispatched sessions (repeatable)]:config:_files' \
      '--model[Default model for sessions dispatched from agent view]:model:' \
      '--permission-mode[Default permission mode for sessions dispatched from agent view]:mode:(acceptEdits bypassPermissions default dontAsk plan auto)' \
      '*--plugin-dir[Load plugins from specified directory for the agent view and dispatched sessions (repeatable)]:path:_files -/' \
      '--setting-sources[Comma-separated list of setting sources to load (user, project, local)]:sources:' \
      '--settings[Settings file or JSON string to apply to the agent view and dispatched sessions]:file-or-json:_files' \
      '--strict-mcp-config[Only use MCP servers from --mcp-config in dispatched sessions]'
    return
    ;;
  attach|logs|stop|kill|rm)
    # The leading ':cmd:' placeholder accounts for the subcommand word
    # already in $words — _arguments here is invoked as `claude`'s completer
    # and counts positionals from $words[2], so position 1 = the subcommand
    # itself and position 2 is the actual session-id slot.
    _arguments \
      '(-h --help)'{-h,--help}'[Display help for command]' \
      ':cmd:' \
      ':session:_claude_background_session_ids'
    return
    ;;
  respawn)
    _arguments \
      '(--all)--all[Restart every stopped session]' \
      '(-h --help)'{-h,--help}'[Display help for command]' \
      ':cmd:' \
      '(--all):session:_claude_background_session_ids'
    return
    ;;
  auth)
    if (( CURRENT == sub1 )); then
      _describe 'auth command' auth_commands
    else
      case $words[$sub1] in
        login)
          _arguments \
            '--claudeai[Use Claude subscription (default)]' \
            '--console[Use Anthropic Console (API usage billing) instead of Claude subscription]' \
            '--email[Pre-populate email address on the login page]:email:' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '--sso[Force SSO login flow]'
          ;;
        logout)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]'
          ;;
        status)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '--json[Output as JSON (default)]' \
            '--text[Output as human-readable text]'
          ;;
        *)
          _message 'no more arguments'
          ;;
      esac
    fi
    return
    ;;
  mcp)
    if (( CURRENT == sub1 )); then
      _describe 'mcp command' mcp_commands
    else
      case $words[$sub1] in
        serve)
          _arguments \
            '(-d --debug)'{-d,--debug}'[Enable debug mode]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '--verbose[Override verbose mode setting from config]'
          ;;
        add)
          _arguments \
            '--callback-port[Fixed port for OAuth callback (for servers requiring pre-registered redirect URIs)]:port:' \
            '--client-id[OAuth client ID for HTTP/SSE servers]:clientId:' \
            '--client-secret[Prompt for OAuth client secret (or set MCP_CLIENT_SECRET env var)]' \
            '(-e --env)*'{-e,--env}'[Set environment variables (e.g. -e KEY=value)]:env:' \
            '(-H --header)*'{-H,--header}'[Set WebSocket headers (e.g. -H "X-Api-Key: abc123" -H "X-Custom: value")]:header:' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Configuration scope (local, user, or project) (default: local)]:scope:(local user project)' \
            '(-t --transport)'{-t,--transport}'[Transport type (stdio, sse, http). Defaults to stdio if not specified]:transport:(stdio sse http)' \
            ':name:' \
            ':commandOrUrl:_files' \
            '*:args:_files'
          ;;
        remove)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Configuration scope (local, user, or project) - if not specified, removes from whichever scope it exists in]:scope:(local user project)' \
            ':name:'
          ;;
        add-json)
          _arguments \
            '--client-secret[Prompt for OAuth client secret (or set MCP_CLIENT_SECRET env var)]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Configuration scope (local, user, or project) (default: local)]:scope:(local user project)' \
            ':name:' \
            ':json:'
          ;;
        add-from-claude-desktop)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Configuration scope (local, user, or project) (default: local)]:scope:(local user project)'
          ;;
        get)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            ':name:'
          ;;
        list|reset-project-choices)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]'
          ;;
        *)
          _message 'no more arguments'
          ;;
      esac
    fi
    return
    ;;
  plugin|plugins)
    if (( CURRENT == sub1 )); then
      _describe 'plugin command' plugin_commands
    else
      case $words[$sub1] in
        details)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            ':name:'
          ;;
        tag)
          _arguments \
            '--dry-run[Print what would be tagged without creating it]' \
            '(-f --force)'{-f,--force}'[Skip the dirty-working-tree and tag-already-exists checks]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-m --message)'{-m,--message}'[Tag annotation message (use %s for the version)]:msg:' \
            '--push[Push the tag to --remote after creating it]' \
            '--remote[Remote to push to with --push (default: origin)]:name:' \
            '::path:_files'
          ;;
        validate)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            ':path:_files'
          ;;
        marketplace)
          local sub2=$(( subcmd_pos + 2 ))
          if (( CURRENT == sub2 )); then
            _describe 'marketplace command' marketplace_commands
          else
            case $words[$sub2] in
              add)
                _arguments \
                  '(-h --help)'{-h,--help}'[Display help]' \
                  '--scope[Where to declare the marketplace: user (default), project, or local]:scope:(user project local)' \
                  '*--sparse[Limit checkout to specific directories via git sparse-checkout (for monorepos)]:path:_files -/' \
                  ':source:_files'
                ;;
              remove|rm)
                _arguments \
                  '(-h --help)'{-h,--help}'[Display help]' \
                  ':name:'
                ;;
              update)
                _arguments \
                  '(-h --help)'{-h,--help}'[Display help]' \
                  '::name:'
                ;;
              list)
                _arguments \
                  '(-h --help)'{-h,--help}'[Display help]' \
                  '--json[Output as JSON]'
                ;;
              *)
                _message 'no more arguments'
                ;;
            esac
          fi
          ;;
        install|i)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Installation scope: user, project, or local (default: user)]:scope:(user project local)' \
            ':plugin:'
          ;;
        prune|autoremove)
          _arguments \
            '--dry-run[List what would be removed without removing]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Prune at scope: user, project, or local (default: user)]:scope:(user project local)' \
            '(-y --yes)'{-y,--yes}'[Skip the confirmation prompt (required when stdin is not a TTY)]'
          ;;
        uninstall|remove)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '--keep-data[Preserve the plugin'\''s persistent data directory (~/.claude/plugins/data/{id}/)]' \
            '--prune[Also remove auto-installed dependencies that are no longer needed (requires -y in non-interactive contexts)]' \
            '(-s --scope)'{-s,--scope}'[Uninstall from scope: user, project, or local (default: user)]:scope:(user project local)' \
            '(-y --yes)'{-y,--yes}'[Skip the --prune confirmation prompt (required when stdin is not a TTY)]' \
            ':plugin:'
          ;;
        enable)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Installation scope: user, project, local (default: auto-detect)]:scope:(user project local)' \
            ':plugin:'
          ;;
        disable)
          _arguments \
            '(-a --all)'{-a,--all}'[Disable all enabled plugins]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Installation scope: user, project, local (default: auto-detect)]:scope:(user project local)' \
            '::plugin:'
          ;;
        update)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-s --scope)'{-s,--scope}'[Installation scope: user, project, local, managed (default: user)]:scope:(user project local managed)' \
            ':plugin:'
          ;;
        list)
          _arguments \
            '--available[Include available plugins from marketplaces (requires --json)]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '--json[Output as JSON]'
          ;;
        *)
          _message 'no more arguments'
          ;;
      esac
    fi
    return
    ;;
  project)
    if (( CURRENT == sub1 )); then
      local -a project_commands
      project_commands=(
        'help:Display help for command'
        'purge:Delete all Claude Code state for a project (transcripts, tasks, file history, config entry)'
      )
      _describe 'project command' project_commands
    else
      case $words[$sub1] in
        purge)
          _arguments \
            '--all[Purge state for every project (mutually exclusive with path)]' \
            '--dry-run[List what would be deleted without deleting anything]' \
            '(-h --help)'{-h,--help}'[Display help]' \
            '(-i --interactive)'{-i,--interactive}'[Prompt for each item before deleting]' \
            '(-y --yes)'{-y,--yes}'[Skip confirmation prompt]' \
            '::path:_files -/'
          ;;
        *)
          _message 'no more arguments'
          ;;
      esac
    fi
    return
    ;;
  auto-mode)
    if (( CURRENT == sub1 )); then
      local -a auto_mode_commands
      auto_mode_commands=(
        'config:Print the effective auto mode config as JSON: your settings where set, defaults otherwise'
        'critique:Get AI feedback on your custom auto mode rules'
        'defaults:Print the default auto mode environment, allow, soft_deny, and hard_deny rules as JSON'
        'help:Display help for command'
      )
      _describe 'auto-mode command' auto_mode_commands
    else
      case $words[$sub1] in
        critique)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]' \
            '--model[Override which model is used]:model:'
          ;;
        config|defaults)
          _arguments \
            '(-h --help)'{-h,--help}'[Display help]'
          ;;
        *)
          _message 'no more arguments'
          ;;
      esac
    fi
    return
    ;;
  install)
    _arguments \
      '--force[Force installation even if already installed]' \
      '(-h --help)'{-h,--help}'[Display help]' \
      ':target:(stable latest)'
    return
    ;;
  remote-control)
    _arguments \
      '(-h --help)'{-h,--help}'[Display help]' \
      '--sandbox[Enable sandboxing for filesystem and network isolation]' \
      '--no-sandbox[Disable sandboxing]' \
      '--verbose[Show detailed connection and session logs]'
    return
    ;;
  ultrareview)
    _arguments \
      '(-h --help)'{-h,--help}'[Display help]' \
      '--json[Print the raw bugs.json payload instead of formatted findings]' \
      '--timeout[Maximum minutes to wait for the review to finish (default: 30)]:minutes:' \
      '::target:'
    return
    ;;
  setup-token|doctor|update|upgrade)
    _arguments \
      '(-h --help)'{-h,--help}'[Display help]'
    return
    ;;
esac
fi # end: if [[ -n "$subcmd" ]]

